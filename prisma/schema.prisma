// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id    String @id @default(uuid())
  login String
  pwd   String
  role  Role
  sub   Sub?   @relation("UserSelfSub")
}

model Sub {
  id                  String   @id @default(uuid())
  externalId          String   @unique
  login               String   @unique
  pwd                 String
  package             Package?
  note                String
  user                User?    @relation("UserSelfSub", fields: [userId], references: [id])
  userId              String?  @unique
  attractedSubs       Sub[]    @relation("SubOnSub")
  attractedBy         Sub?     @relation("SubOnSub", fields: [attractorId], references: [id])
  attractorId         String?
  secondarySubsAmount Int      @default(0)
  playlist            String
  epg                 String
  archive             String
  stalkerPortal       String
}

model Package {
  id             Int             @id @default(autoincrement())
  pkgType        PackageType
  startDate      DateTime
  endDate        DateTime
  sub            Sub             @relation(fields: [subId], references: [id])
  subId          String          @unique
  paymentDetails PaymentDetails?
}

model PaymentDetails {
  id            Int      @id @default(autoincrement())
  paymentDate   DateTime
  paymentAmount Int
  paymentCurr   Currency
  package       Package  @relation(fields: [packageId], references: [id])
  packageId     Int      @unique
}

enum Currency {
  USD
  EUR
}

enum PackageType {
  REGULAR
  PREMIUM
}

enum Role {
  ADMIN
  PARTNER
}
