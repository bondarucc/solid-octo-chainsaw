// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id    String @id @default(uuid())
  login String @unique
  pwd   String
  role  Role
  sub   Sub    @relation(fields: [subId], references: [id])
  subId String @unique
}

model Sub {
  id                 String  @id @default(uuid())
  externalId         String  @unique
  login              String? @unique
  pwd                String?
  note               String?
  attractorId        String?
  m3uPlaylist        String?
  epg                String?
  publicKey          String?
  media              String?
  totalPayableReward Int     @default(0)

  //relations
  user User?

  package Package?

  attractedSubs Sub[] @relation("SubOnSub")
  attractedBy   Sub?  @relation("SubOnSub", fields: [attractorId], references: [id])

  //Audit event refs
  sc_ae  SC_AE?
  srt_ae SRT_AE[]
  sr_ae  SR_AE[]
  su_ae  SU_AE[]
  // sssai_ae SSSAI_AE[]
}

model Package {
  id            String       @id @default(uuid())
  pkgType       PackageType?
  startDate     DateTime
  endDate       DateTime
  sub           Sub          @relation(fields: [subId], references: [id])
  subId         String       @unique
  region        Region?
  paymentDate   DateTime?
  paymentAmount Int?
  paymentCurr   Currency?
  spe_ae        SPE_AE[]
}

model SC_AE {
  id            String   @id @default(uuid())
  sub           Sub      @relation(fields: [subId], references: [id])
  subId         String   @unique
  attractorTier Int?
  timestamp     DateTime
  spe_ae        SPE_AE?
  srt_ae        SRT_AE[]
  // sssai_ae      SSSAI_AE[]

  @@map("SubCreatedAuditEvent")
}

model SPE_AE {
  id          String   @id @default(uuid())
  package     Package  @relation(fields: [pkgId], references: [id])
  pkgId       String
  prevEndDate DateTime
  newEndDate  DateTime
  timestamp   DateTime
  sc_ae       SC_AE?   @relation(fields: [sc_ae_id], references: [id])
  sc_ae_id    String?  @unique

  @@map("SubPackageExtendedAuditEvent")
}

model SRT_AE {
  id                     String             @id @default(uuid())
  sub                    Sub                @relation(fields: [subId], references: [id])
  subId                  String
  // secondarySubsAmount    Int
  // directSubsAmount       Int
  // totalTier              Int
  rewardType             MonetaryRewardType
  timestamp              DateTime
  sc_ae                  SC_AE              @relation(fields: [sc_ae_id], references: [id])
  sc_ae_id               String
  rewardAmount           Int
  prevTotalPayableReward Int
  newTotalPayableReward  Int

  @@map("SubRewardTriggeredAuditEvent")
}

model SR_AE {
  id                     String   @id @default(uuid())
  sub                    Sub      @relation(fields: [subId], references: [id])
  subId                  String
  timestamp              DateTime
  repaymentAmount        Int
  prevTotalPayableReward Int
  newTotalPayableReward  Int

  @@map("SubRepaymentAuditEvent")
}

model SU_AE {
  id        String   @id @default(uuid())
  sub       Sub      @relation(fields: [subId], references: [id])
  subId     String
  reason    String?
  timestamp DateTime
  diff      String

  @@map("SubUpdatedtAuditEvent")
}

enum MonetaryRewardType {
  SUB_EXT
  NEW_SUB
}

enum Currency {
  USD
  EUR
}

enum PackageType {
  REGULAR
  PREMIUM
}

enum Role {
  ADMIN
  PARTNER
}

enum Region {
  EU
  USA_CANADA
}
