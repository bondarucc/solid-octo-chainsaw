// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id    String @id @default(uuid())
  login String
  pwd   String
  role  Role
  sub   Sub    @relation(fields: [subId], references: [id])
  subId String @unique
}

model Sub {
  id                  String     @id @default(uuid())
  externalId          String     @unique
  login               String?    @unique
  pwd                 String?
  package             Package?
  note                String?
  user                User?
  attractedSubs       Sub[]      @relation("SubOnSub")
  attractedBy         Sub?       @relation("SubOnSub", fields: [attractorId], references: [id])
  attractorId         String?
  secondarySubsAmount Int        @default(0)
  playlist            String?
  epg                 String?
  archive             String?
  stalkerPortal       String?
  totalPayableReward  Int        @default(0)
  sc_ae               SC_AE?
  srt_ae              SRT_AE[]
  sssai_ae            SSSAI_AE[]
}

model Package {
  id            String       @id @default(uuid())
  pkgType       PackageType?
  startDate     DateTime
  endDate       DateTime
  sub           Sub          @relation(fields: [subId], references: [id])
  subId         String       @unique
  // paymentDetails   PaymentDetails @relation(fields: [paymentDetailsId], references: [id])
  // paymentDetailsId String         @unique
  paymentDate   DateTime?
  paymentAmount Int?
  paymentCurr   Currency?
  spe_ae        SPE_AE[]
}

model SC_AE {
  id        String     @id @default(uuid())
  sub       Sub        @relation(fields: [subId], references: [id])
  subId     String     @unique
  timestamp DateTime
  spe_ae    SPE_AE?
  srt_ae    SRT_AE?
  sssai_ae  SSSAI_AE[]

  @@map("SubCreatedAuditEvent")
}

model SPE_AE {
  id                  String   @id @default(uuid())
  package             Package  @relation(fields: [pkgId], references: [id])
  pkgId               String
  prevEndDate         DateTime
  newEndDate          DateTime
  secondarySubsAmount Int
  directSubsAmount    Int
  totalTier           Int
  timestamp           DateTime
  sc_ae               SC_AE    @relation(fields: [sc_ae_id], references: [id])
  sc_ae_id            String   @unique

  @@map("SubPackageExtendedAuditEvent")
}

model SRT_AE {
  id                     String   @id @default(uuid())
  sub                    Sub      @relation(fields: [subId], references: [id])
  subId                  String
  secondarySubsAmount    Int
  directSubsAmount       Int
  totalTier              Int
  timestamp              DateTime
  sc_ae                  SC_AE    @relation(fields: [sc_ae_id], references: [id])
  sc_ae_id               String   @unique
  rewardAmount           Int
  prevTotalPayableReward Int
  newTotalPayableReward  Int

  @@map("SubRewardTriggeredAuditEvent")
}

model SSSAI_AE {
  id                      String   @id @default(uuid())
  sc_ae                   SC_AE    @relation(fields: [sc_ae_id], references: [id])
  sc_ae_id                String
  timestamp               DateTime
  prevSecondarySubsAmount Int
  newSecondarySubsAmount  Int
  sub                     Sub      @relation(fields: [subId], references: [id])
  subId                   String

  @@map("SubSecondarySubsAmountIncrementedAuditEvent")
}

enum Currency {
  USD
  EUR
}

enum PackageType {
  REGULAR
  PREMIUM
}

enum Role {
  ADMIN
  PARTNER
}
